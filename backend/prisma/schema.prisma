generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  KULLANICI
  ADMIN
}

model Kullanici {
  id              Int      @id @default(autoincrement())
  adSoyad         String
  email           String   @unique
  sifreHash       String
  telefon         String?
  adres           String?
  rol             Rol      @default(KULLANICI)
  olusturmaTarihi DateTime @default(now())

  @@map("kullanicilar")
}

model Kategori {
  id       Int    @id @default(autoincrement())
  ad       String @unique
  aciklama String?
  urunler  Urun[]


  @@map("kategoriler")
}
model Urun {
  id              Int      @id @default(autoincrement())
  ad              String
  aciklama        String?
  fiyat           Decimal  @db.Decimal(10, 2)
  stokAdedi       Int      @default(0)
  gorselUrl       String?
  kategoriId      Int
  kategori        Kategori @relation(fields: [kategoriId], references: [id])
  aktif           Boolean  @default(true)
  olusturmaTarihi DateTime @default(now())

  @@map("urunler")
}
model TeslimatBolgesi {
  id             Int     @id @default(autoincrement())
  bolgeAdi       String  @unique
  teslimatUcreti Decimal @db.Decimal(10, 2)

  @@map("teslimat_bolgeleri")
}