generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  KULLANICI
  ADMIN
}

model Kullanici {
  id              Int      @id @default(autoincrement())
  adSoyad         String
  email           String   @unique
  sifreHash       String
  telefon         String?
  adres           String?
  rol             Rol      @default(KULLANICI)
  olusturmaTarihi DateTime @default(now())

  @@map("kullanicilar")
}

model Kategori {
  id       Int    @id @default(autoincrement())
  ad       String @unique
  aciklama String?

  @@map("kategoriler")
}