generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  KULLANICI
  ADMIN
}

model Kullanici {
  id              Int       @id @default(autoincrement())
  adSoyad         String
  email           String    @unique
  sifreHash       String
  telefon         String?
  adres           String?
  rol             Rol       @default(KULLANICI)
  siparisler      Siparis[]
  olusturmaTarihi DateTime  @default(now())

  @@map("kullanicilar")
}

model Kategori {
  id       Int     @id @default(autoincrement())
  ad       String  @unique
  aciklama String?
  urunler  Urun[]

  @@map("kategoriler")
}

model Urun {
  id               Int             @id @default(autoincrement())
  ad               String
  aciklama         String?
  fiyat            Decimal         @db.Decimal(10, 2)
  stokAdedi        Int             @default(0)
  gorselUrl        String?
  kategoriId       Int
  kategori         Kategori        @relation(fields: [kategoriId], references: [id])
  aktif            Boolean         @default(true)
  siparisKalemleri SiparisKalemi[]
  olusturmaTarihi  DateTime        @default(now())

  @@map("urunler")
}

model TeslimatBolgesi {
  id             Int       @id @default(autoincrement())
  bolgeAdi       String    @unique
  siparisler     Siparis[]
  teslimatUcreti Decimal   @db.Decimal(10, 2)

  @@map("teslimat_bolgeleri")
}

enum SiparisDurumu {
  ALINDI
  HAZIRLANIYOR
  YOLDA
  TESLIM_EDILDI
  IPTAL
}

model Siparis {
  id                Int             @id @default(autoincrement())
  kullaniciId       Int
  kullanici         Kullanici       @relation(fields: [kullaniciId], references: [id])
  teslimatBolgesiId Int
  teslimatBolgesi   TeslimatBolgesi @relation(fields: [teslimatBolgesiId], references: [id])
  teslimatAdresi    String
  aliciAdSoyad      String
  aliciTelefon      String
  urunToplami       Decimal         @db.Decimal(10, 2)
  teslimatUcreti    Decimal         @db.Decimal(10, 2)
  genelToplam       Decimal         @db.Decimal(10, 2)
  durum             SiparisDurumu   @default(ALINDI)
  not               String?
  olusturmaTarihi   DateTime        @default(now())

  kalemler SiparisKalemi[]

  @@map("siparisler")
}

model SiparisKalemi {
  id         Int     @id @default(autoincrement())
  siparisId  Int
  siparis    Siparis @relation(fields: [siparisId], references: [id])
  urunId     Int
  urun       Urun    @relation(fields: [urunId], references: [id])
  adet       Int
  birimFiyat Decimal @db.Decimal(10, 2)

  @@map("siparis_kalemleri")
}
